    "children": [
      "rich-text#footer-mobile-sobre-nos-titulo"
    ],
    "props": {
      "blockClass": "footer-mobile-menu-trigger"
    }
  },
  "rich-text#footer-mobile-sobre-nos-titulo": {
    "props": {
      "text": "Institucional",
      "blockClass": "footer-mobile-menu-title"
    }
  },
  "disclosure-content#footer-mobile-sobre-nos": {
    "children": [
      "vtex.menu@2.x:menu#Institucional"
    ],
    "props": {
      "blockClass": "footer-mobile-menu-content"
    }
  },


  










