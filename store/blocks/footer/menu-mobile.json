{
  "disclosure-layout-group#mobile-menu-mobile": {
    "children": [
      "flex-layout.col#footer-mobile-sobre-nos",
      "flex-layout.col#footer-mobile-ajuda-e-suporte",
      "flex-layout.col#footer-mobile-fale-conosco",
      "flex-layout.col#footer-mobile-fale-conosco2"
    ],
    "props": {
      "animated": true,
      "blockClass": "footer-mobile-menu-wrapper"
    }
  },



  

  "flex-layout.col#footer-mobile-sobre-nos": {
    "children": [
      "disclosure-layout#footer-mobile-sobre-nos"
    ]
